<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageType>Template</PackageType>
    <PackageId>StrawhatsCompany.SHFramework.Templates</PackageId>
    <PackageVersion>3.6.0</PackageVersion>
    <Title>Strawhats Framework Templates</Title>
    <Authors>Strawhats Company</Authors>
    <Description>Templates for creating Strawhats framework services.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseFile>LICENSE</PackageLicenseFile>
    <PackageProjectUrl>https://github.com/StrawhatsCompany/sh-framework-template</PackageProjectUrl>
    <RepositoryUrl>https://github.com/StrawhatsCompany/sh-framework-template</RepositoryUrl>
    <RepositoryType>git</RepositoryType>
    <PackageTags>dotnet-new;templates;strawhats;framework;webapi</PackageTags>
    <EnableDefaultItems>false</EnableDefaultItems>
    <NoDefaultExcludes>true</NoDefaultExcludes>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <IncludeContentInPack>true</IncludeContentInPack>
    <ContentTargetFolders>content</ContentTargetFolders>
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
    <None Include="..\LICENSE" Pack="true" PackagePath="\" />
    <Content Include="**\*"
             Exclude=".git\**;.idea\**;**\bin\**;**\obj\**;artifacts\**;*.DotSettings.user;README.md;StrawhatsCompany.SHFramework.Templates.csproj" />
  </ItemGroup>

</Project>
